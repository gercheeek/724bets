--- a/index.css
+++ b/index.css
@@ -166,6 +166,48 @@ html, body {
   animation: fade-in 0.5s ease-out forwards;
 }
 
+/* ===== Logo Intro Animations ===== */
+@keyframes clover-intro-pulse {
+  0% { transform: scale(1) rotate(0deg); }
+  15% { transform: scale(0.7) rotate(-15deg); }
+  35% { transform: scale(1.2) rotate(15deg); }
+  50% { transform: scale(1) rotate(0deg); }
+  100% { transform: scale(1) rotate(0deg); }
+}
+
+@keyframes text-intro-collapse {
+  0% { max-width: 150px; opacity: 1; transform: scale(1) translateX(0); }
+  15% { transform: scale(0.7) translateX(0); max-width: 150px; opacity: 1; }
+  35% { transform: scale(1.2) translateX(0); max-width: 150px; opacity: 1; }
+  50% { transform: scale(1) translateX(0); max-width: 150px; opacity: 1; }
+  65% { max-width: 150px; opacity: 1; transform: scale(1) translateX(0); }
+  100% { max-width: 0px; opacity: 0; margin-left: 0; padding-left: 0; padding-right: 0; transform: scale(0.2) translateX(-50px); }
+}
+
+.logo-clover-intro {
+  animation: clover-intro-pulse 2.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
+}
+
+.logo-text-intro {
+  display: inline-flex;
+  align-items: center;
+  overflow: hidden;
+  white-space: nowrap;
+  transform-origin: left center;
+  animation: text-intro-collapse 2.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
+}
+
+@keyframes delayed-fade-in {
+  0% { opacity: 0; transform: translateX(30px) scale(0.9); }
+  100% { opacity: 1; transform: translateX(0) scale(1); }
+}
+
+.balance-intro-fade {
+  animation: delayed-fade-in 1s cubic-bezier(0.4, 0, 0.2, 1) 2.5s both;
+  transform-origin: right center;
+}
+
+
 /* ===== Header — Two-Tier Bilyoner Layout ===== */
 .header-wrapper {
   position: relative;
